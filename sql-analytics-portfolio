### 01 — SaaS ARR & MRR Calculations
```sql
-- Monthly Recurring Revenue with MoM growth
WITH monthly_mrr AS (
    SELECT
        DATE_TRUNC('month', subscription_date)     AS month,
        SUM(annual_contract_value / 12)            AS mrr,
        COUNT(DISTINCT customer_id)                AS active_customers
    FROM subscriptions
    WHERE status = 'active'
    GROUP BY 1
),
mrr_with_growth AS (
    SELECT
        month,
        mrr,
        active_customers,
        LAG(mrr) OVER (ORDER BY month)             AS prev_mrr,
        ROUND(
            (mrr - LAG(mrr) OVER (ORDER BY month))
            / NULLIF(LAG(mrr) OVER (ORDER BY month), 0) * 100, 2
        )                                          AS mom_growth_pct
    FROM monthly_mrr
)
SELECT
    month,
    ROUND(mrr, 2)                                  AS mrr,
    ROUND(mrr * 12, 2)                             AS arr_run_rate,
    active_customers,
    mom_growth_pct,
    SUM(mrr) OVER (ORDER BY month ROWS BETWEEN 2 PRECEDING AND CURRENT ROW)
                                                   AS rolling_3mo_mrr
FROM mrr_with_growth
ORDER BY month;
```

