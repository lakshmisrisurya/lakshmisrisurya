### 05 — Budget vs Actuals Variance Analysis
```sql
-- Finance: budget vs actuals with variance flags
WITH actuals AS (
    SELECT
        department,
        cost_center,
        gl_account,
        DATE_TRUNC('month', transaction_date)       AS month,
        SUM(amount)                                 AS actual_spend
    FROM general_ledger
    WHERE fiscal_year = 2024
    GROUP BY 1, 2, 3, 4
),
budget AS (
    SELECT
        department,
        cost_center,
        gl_account,
        budget_month                                AS month,
        budget_amount
    FROM annual_budget
    WHERE fiscal_year = 2024
),
variance AS (
    SELECT
        COALESCE(a.department, b.department)        AS department,
        COALESCE(a.cost_center, b.cost_center)      AS cost_center,
        COALESCE(a.gl_account, b.gl_account)        AS gl_account,
        COALESCE(a.month, b.month)                  AS month,
        COALESCE(b.budget_amount, 0)                AS budget,
        COALESCE(a.actual_spend, 0)                 AS actuals,
        COALESCE(a.actual_spend, 0)
            - COALESCE(b.budget_amount, 0)          AS variance_amt,
        ROUND(
            (COALESCE(a.actual_spend, 0)
            - COALESCE(b.budget_amount, 0))
            / NULLIF(b.budget_amount, 0) * 100, 2
        )                                           AS variance_pct
    FROM actuals a
    FULL OUTER JOIN budget b
        USING (department, cost_center, gl_account, month)
)
SELECT
    *,
    CASE
        WHEN variance_pct > 10  THEN '🔴 Over Budget'
        WHEN variance_pct > 5   THEN '🟡 Watch'
        WHEN variance_pct < -10 THEN '🟢 Under Budget'
        ELSE                         '✅ On Track'
    END                                             AS budget_status,
    SUM(actuals) OVER (
        PARTITION BY department
        ORDER BY month
    )                                               AS ytd_actuals,
    SUM(budget) OVER (
        PARTITION BY department
        ORDER BY month
    )                                               AS ytd_budget
FROM variance
ORDER BY department, month;
```

