### 03 — Net Revenue Retention (NRR)
```sql
-- NRR: measures expansion, contraction, and churn vs prior period
WITH period_revenue AS (
    SELECT
        customer_id,
        DATE_TRUNC('month', month)                  AS month,
        SUM(mrr)                                    AS current_mrr
    FROM subscriptions
    GROUP BY 1, 2
),
revenue_comparison AS (
    SELECT
        curr.month,
        curr.customer_id,
        curr.current_mrr,
        COALESCE(prev.current_mrr, 0)               AS prior_mrr,
        CASE
            WHEN prev.current_mrr IS NULL            THEN 'new'
            WHEN curr.current_mrr > prev.current_mrr THEN 'expansion'
            WHEN curr.current_mrr < prev.current_mrr THEN 'contraction'
            WHEN curr.current_mrr = 0                THEN 'churned'
            ELSE 'retained'
        END                                         AS revenue_type
    FROM period_revenue curr
    LEFT JOIN period_revenue prev
        ON curr.customer_id = prev.customer_id
        AND curr.month = DATEADD('month', 1, prev.month)
)
SELECT
    month,
    SUM(CASE WHEN revenue_type = 'retained'    THEN current_mrr ELSE 0 END) AS retained_mrr,
    SUM(CASE WHEN revenue_type = 'expansion'   THEN current_mrr ELSE 0 END) AS expansion_mrr,
    SUM(CASE WHEN revenue_type = 'contraction' THEN prior_mrr - current_mrr ELSE 0 END) AS contraction_mrr,
    SUM(CASE WHEN revenue_type = 'churned'     THEN prior_mrr ELSE 0 END)   AS churned_mrr,
    ROUND(
        SUM(CASE WHEN revenue_type IN ('retained','expansion','contraction') THEN current_mrr ELSE 0 END)
        / NULLIF(SUM(prior_mrr), 0) * 100, 2
    )                                                                        AS nrr_pct
FROM revenue_comparison
GROUP BY month
ORDER BY month;
```

