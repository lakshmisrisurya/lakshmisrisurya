### 06 — Customer Segmentation (RFM Analysis)
```sql
-- RFM: Recency, Frequency, Monetary segmentation
WITH rfm_base AS (
    SELECT
        customer_id,
        DATEDIFF('day', MAX(order_date), CURRENT_DATE) AS recency_days,
        COUNT(DISTINCT order_id)                        AS frequency,
        SUM(order_value)                                AS monetary
    FROM orders
    WHERE order_date >= DATEADD('year', -1, CURRENT_DATE)
    GROUP BY 1
),
rfm_scores AS (
    SELECT
        customer_id,
        recency_days,
        frequency,
        monetary,
        NTILE(5) OVER (ORDER BY recency_days ASC)   AS r_score,
        NTILE(5) OVER (ORDER BY frequency DESC)     AS f_score,
        NTILE(5) OVER (ORDER BY monetary DESC)      AS m_score
    FROM rfm_base
),
rfm_segments AS (
    SELECT
        *,
        CONCAT(r_score, f_score, m_score)           AS rfm_cell,
        ROUND((r_score + f_score + m_score) / 3.0, 2) AS rfm_avg
    FROM rfm_scores
)
SELECT
    customer_id,
    recency_days,
    frequency,
    ROUND(monetary, 2)                              AS monetary,
    rfm_cell,
    rfm_avg,
    CASE
        WHEN rfm_avg >= 4.5                         THEN 'Champions'
        WHEN rfm_avg >= 4.0                         THEN 'Loyal Customers'
        WHEN rfm_avg >= 3.0 AND r_score >= 3        THEN 'Potential Loyalists'
        WHEN r_score >= 4   AND f_score <= 2        THEN 'New Customers'
        WHEN rfm_avg >= 3.0 AND r_score <= 2        THEN 'At Risk'
        WHEN r_score <= 2   AND rfm_avg >= 3.0      THEN 'Cannot Lose Them'
        ELSE                                             'Hibernating'
    END                                             AS customer_segment
FROM rfm_segments
ORDER BY rfm_avg DESC;
```

