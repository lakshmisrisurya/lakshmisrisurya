### 04 — Retail Sales Performance with Rankings
```sql
-- Store and product performance with rankings and running totals
WITH daily_sales AS (
    SELECT
        store_id,
        product_id,
        product_category,
        sale_date,
        SUM(quantity)                               AS units_sold,
        SUM(revenue)                                AS daily_revenue
    FROM sales_transactions
    WHERE sale_date >= DATEADD('month', -3, CURRENT_DATE)
    GROUP BY 1, 2, 3, 4
),
product_totals AS (
    SELECT
        product_id,
        product_category,
        SUM(units_sold)                             AS total_units,
        SUM(daily_revenue)                          AS total_revenue,
        AVG(daily_revenue)                          AS avg_daily_revenue,
        COUNT(DISTINCT sale_date)                   AS selling_days
    FROM daily_sales
    GROUP BY 1, 2
)
SELECT
    product_id,
    product_category,
    total_units,
    ROUND(total_revenue, 2)                         AS total_revenue,
    ROUND(avg_daily_revenue, 2)                     AS avg_daily_revenue,
    RANK() OVER (PARTITION BY product_category
                 ORDER BY total_revenue DESC)       AS rank_in_category,
    RANK() OVER (ORDER BY total_revenue DESC)       AS overall_rank,
    ROUND(
        SUM(total_revenue) OVER (PARTITION BY product_category
                                 ORDER BY total_revenue DESC)
        / SUM(total_revenue) OVER (PARTITION BY product_category) * 100
    , 2)                                            AS cumulative_category_pct,
    NTILE(4) OVER (ORDER BY total_revenue DESC)     AS revenue_quartile
FROM product_totals
ORDER BY overall_rank;
```

